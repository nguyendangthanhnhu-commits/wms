generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin
  warehouse_manager
  warehouse_keeper
  qc_officer
  production_staff
  forklift_driver
  sales
  leader
}

enum ProductType {
  component
  consumable
  tool
  finished_good
}

enum WarehouseGroup {
  component
  finished_good
  production
  quality
  defect
}

enum OrderType {
  processing
  commercial
}

enum OrderStatus {
  draft
  confirmed
  in_production
  partial_done
  completed
  cancelled
}

enum VoucherType {
  PN
  PX_YC
  PX
  PCT
  PNT
  PXT
  PBL
  PQC
}

enum VoucherStatus {
  draft
  pending
  approved
  in_progress
  completed
  rejected
  cancelled
}

enum DefectType {
  original
  production
}

enum DefectResolution {
  return_supplier
  destroy
  repair_reuse
  pending
}

enum CheckType {
  shift_start
  shift_end
  periodic
  spot_check
}

enum ShiftName {
  shift_1
  shift_2
  shift_3
  admin
}

enum PurchaseOrderStatus {
  ordered
  in_transit
  partial_received
  completed
  cancelled
}

model Department {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  users     User[]
  createdAt DateTime @default(now())
}

model User {
  id           String      @id @default(uuid())
  employeeCode String      @unique
  fullName     String
  phone        String?
  avatarUrl    String?
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  role         UserRole    @default(production_staff)
  pinHash      String?
  faceVector   Json?
  defaultShift ShiftName   @default(shift_1)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  warehouseAssignments  WarehouseStaffAssignment[]
  managedWarehouses     Warehouse[]
  createdVouchers       StockVoucher[]          @relation("CreatedBy")
  approvedVouchers      StockVoucher[]          @relation("ApprovedBy")
  confirmedVoucherItems StockVoucherItem[]
  checkSessionsStarted  InventoryCheckSession[] @relation("SessionStartedBy")
  checkSessionsApproved InventoryCheckSession[] @relation("SessionApprovedBy")
  checkPhotos           InventoryCheckPhoto[]
  voucherAttachments    VoucherAttachment[]
  qcEvaluations         QcEvaluation[]          @relation("EvaluatedBy")
  responsibleDefects    QcEvaluation[]          @relation("ResponsibleUser")
  defectReports         DefectReport[]
  productionOutputs     ProductionOutput[]
  bomVersions           BomVersion[]
  salesOrders           SalesOrder[]
  purchaseOrders        PurchaseOrder[]
  notifications         SystemNotification[]
}

model Warehouse {
  id          String         @id @default(uuid())
  code        String         @unique
  name        String
  groupType   WarehouseGroup
  description String?
  capacity    Float?
  managerId   String?
  manager     User?          @relation(fields: [managerId], references: [id])
  isActive    Boolean        @default(true)
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())

  locations              WarehouseLocation[]
  staffAssignments       WarehouseStaffAssignment[]
  productWhitelist       WarehouseProductWhitelist[]
  inventory              Inventory[]
  outgoingVouchers       StockVoucher[]          @relation("FromWarehouse")
  incomingVouchers       StockVoucher[]          @relation("ToWarehouse")
  checkSessions          InventoryCheckSession[]
  bomItems               BomItem[]
  discoveredDefects      DefectReport[]
  responsibleEvaluations QcEvaluation[]          @relation("ResponsibleWarehouse")
}

model WarehouseLocation {
  id          String    @id @default(uuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  rack        String?
  shelf       String?
  bin         String?
  barcode     String?   @unique
  isActive    Boolean   @default(true)

  inventory        Inventory[]
  fromVoucherItems StockVoucherItem[]  @relation("FromLocation")
  toVoucherItems   StockVoucherItem[]  @relation("ToLocation")
  checkItems       InventoryCheckItem[]
}

model WarehouseStaffAssignment {
  id          String    @id @default(uuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  assignedAt  DateTime  @default(now())

  @@unique([warehouseId, userId])
}

model ProductCategory {
  id       String            @id @default(uuid())
  code     String            @unique
  name     String
  parentId String?
  parent   ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryTree")
  products Product[]
}

model Unit {
  id   String @id @default(uuid())
  code String @unique
  name String

  products           Product[]
  fromConversions    UnitConversion[]    @relation("FromUnit")
  toConversions      UnitConversion[]    @relation("ToUnit")
  inventory          Inventory[]
  voucherItems       StockVoucherItem[]
  checkItems         InventoryCheckItem[]
  bomItems           BomItem[]
  salesOrderItems    SalesOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  productionOutputs  ProductionOutput[]
  defectReports      DefectReport[]
}

model Product {
  id            String           @id @default(uuid())
  sku           String           @unique
  name          String
  description   String?
  imageUrl      String?
  productType   ProductType
  categoryId    String?
  category      ProductCategory? @relation(fields: [categoryId], references: [id])
  baseUnitId    String
  baseUnit      Unit             @relation(fields: [baseUnitId], references: [id])
  qrCode        String?          @unique
  barcode       String?          @unique
  minStockLevel Float            @default(0)
  maxStockLevel Float?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  unitConversions   UnitConversion[]
  suppliers         ProductSupplier[]
  whitelist         WarehouseProductWhitelist[]
  inventory         Inventory[]
  bomItems          BomItem[]
  salesOrderItems   SalesOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  voucherItems      StockVoucherItem[]
  defectReports     DefectReport[]
  productionOutputs ProductionOutput[]
  bomVersions       BomVersion[]
  inventoryCheckItems InventoryCheckItem[]
}

model UnitConversion {
  id         String  @id @default(uuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  fromUnitId String
  fromUnit   Unit    @relation("FromUnit", fields: [fromUnitId], references: [id])
  toUnitId   String
  toUnit     Unit    @relation("ToUnit", fields: [toUnitId], references: [id])
  factor     Float

  @@unique([productId, fromUnitId, toUnitId])
}

model Supplier {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  productSuppliers ProductSupplier[]
  purchaseOrders   PurchaseOrder[]
  qcEvaluations    QcEvaluation[]
}

model ProductSupplier {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  supplierSku String?
  isDefault   Boolean  @default(false)
  unitPrice   Float?
  currency    String   @default("VND")

  @@unique([productId, supplierId])
}

model WarehouseProductWhitelist {
  id          String    @id @default(uuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])

  @@unique([warehouseId, productId])
}

model Inventory {
  id              String             @id @default(uuid())
  warehouseId     String
  warehouse       Warehouse          @relation(fields: [warehouseId], references: [id])
  locationId      String?
  location        WarehouseLocation? @relation(fields: [locationId], references: [id])
  productId       String
  product         Product            @relation(fields: [productId], references: [id])
  quantity        Float              @default(0)
  unitId          String
  unit            Unit               @relation(fields: [unitId], references: [id])
  lotNumber       String?
  manufactureDate DateTime?
  expiryDate      DateTime?
  updatedAt       DateTime           @updatedAt

  @@unique([warehouseId, productId, lotNumber])
}

model InventoryTransaction {
  id              String   @id @default(uuid())
  warehouseId     String
  productId       String
  unitId          String
  voucherId       String?
  transactionType String
  quantity        Float
  quantityBefore  Float
  quantityAfter   Float
  lotNumber       String?
  note            String?
  performedById   String
  performedAt     DateTime @default(now())
}

model BomVersion {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  versionName String
  isActive    Boolean  @default(true)
  notes       String?
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  items       BomItem[]
  salesOrders SalesOrder[]

  @@unique([productId, versionName])
}

model BomItem {
  id           String     @id @default(uuid())
  bomVersionId String
  bomVersion   BomVersion @relation(fields: [bomVersionId], references: [id])
  componentId  String
  component    Product    @relation(fields: [componentId], references: [id])
  warehouseId  String
  warehouse    Warehouse  @relation(fields: [warehouseId], references: [id])
  quantity     Float
  unitId       String
  unit         Unit       @relation(fields: [unitId], references: [id])
  sortOrder    Int        @default(0)
  notes        String?
}

model SalesOrder {
  id           String      @id @default(uuid())
  orderCode    String      @unique
  orderType    OrderType
  customerName String
  customerCode String?
  requiredDate DateTime
  status       OrderStatus @default(draft)
  bomVersionId String?
  bomVersion   BomVersion? @relation(fields: [bomVersionId], references: [id])
  notes        String?
  createdById  String?
  createdBy    User?       @relation(fields: [createdById], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  items             SalesOrderItem[]
  vouchers          StockVoucher[]
  purchaseOrders    PurchaseOrder[]
  productionOutputs ProductionOutput[]
}

model SalesOrderItem {
  id           String     @id @default(uuid())
  orderId      String
  order        SalesOrder @relation(fields: [orderId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  quantity     Float
  unitId       String
  unit         Unit       @relation(fields: [unitId], references: [id])
  deliveredQty Float      @default(0)
  unitPrice    Float?
}

model PurchaseOrder {
  id           String              @id @default(uuid())
  orderCode    String              @unique
  supplierId   String
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  salesOrderId String?
  salesOrder   SalesOrder?         @relation(fields: [salesOrderId], references: [id])
  orderType    OrderType?
  expectedDate DateTime?
  status       PurchaseOrderStatus @default(ordered)
  notes        String?
  createdById  String?
  createdBy    User?               @relation(fields: [createdById], references: [id])
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  items    PurchaseOrderItem[]
  vouchers StockVoucher[]
}

model PurchaseOrderItem {
  id          String        @id @default(uuid())
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id])
  productId   String
  product     Product       @relation(fields: [productId], references: [id])
  orderedQty  Float
  receivedQty Float         @default(0)
  unitId      String
  unit        Unit          @relation(fields: [unitId], references: [id])
  unitPrice   Float?
  lotNumber   String?
}

model StockVoucher {
  id              String        @id @default(uuid())
  voucherCode     String        @unique
  voucherType     VoucherType
  status          VoucherStatus @default(draft)
  fromWarehouseId String?
  fromWarehouse   Warehouse?    @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String?
  toWarehouse     Warehouse?    @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  salesOrderId    String?
  salesOrder      SalesOrder?   @relation(fields: [salesOrderId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  vehicleInfo     String?
  driverName      String?
  receiverName    String?
  shift           ShiftName?
  shiftDate       DateTime?
  notes           String?
  createdById     String
  createdBy       User          @relation("CreatedBy", fields: [createdById], references: [id])
  approvedById    String?
  approvedBy      User?         @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items            StockVoucherItem[]
  attachments      VoucherAttachment[]
  defectReport     DefectReport?
  qcEvaluation     QcEvaluation?
  productionOutput ProductionOutput?
}

model StockVoucherItem {
  id             String             @id @default(uuid())
  voucherId      String
  voucher        StockVoucher       @relation(fields: [voucherId], references: [id])
  productId      String
  product        Product            @relation(fields: [productId], references: [id])
  unitId         String
  unit           Unit               @relation(fields: [unitId], references: [id])
  plannedQty     Float
  actualQty      Float?
  lotNumber      String?
  fromLocationId String?
  fromLocation   WarehouseLocation? @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocationId   String?
  toLocation     WarehouseLocation? @relation("ToLocation", fields: [toLocationId], references: [id])
  note           String?
  confirmedById  String?
  confirmedBy    User?              @relation(fields: [confirmedById], references: [id])
  confirmedAt    DateTime?
}

model VoucherAttachment {
  id        String       @id @default(uuid())
  voucherId String
  voucher   StockVoucher @relation(fields: [voucherId], references: [id])
  imageUrl  String
  takenAt   DateTime
  latitude  Float?
  longitude Float?
  takenById String
  takenBy   User         @relation(fields: [takenById], references: [id])
}

model DefectReport {
  id                    String       @id @default(uuid())
  voucherId             String       @unique
  voucher               StockVoucher @relation(fields: [voucherId], references: [id])
  productId             String
  product               Product      @relation(fields: [productId], references: [id])
  quantity              Float
  unitId                String
  unit                  Unit         @relation(fields: [unitId], references: [id])
  discoveredWarehouseId String?
  discoveredWarehouse   Warehouse?   @relation(fields: [discoveredWarehouseId], references: [id])
  description           String
  lotNumber             String?
  status                String       @default("pending_qc")
  reportedById          String
  reportedBy            User         @relation(fields: [reportedById], references: [id])
  reportedAt            DateTime     @default(now())

  qcEvaluation QcEvaluation?
}

model QcEvaluation {
  id                     String           @id @default(uuid())
  voucherId              String           @unique
  voucher                StockVoucher     @relation(fields: [voucherId], references: [id])
  defectReportId         String           @unique
  defectReport           DefectReport     @relation(fields: [defectReportId], references: [id])
  defectType             DefectType
  supplierId             String?
  supplier               Supplier?        @relation(fields: [supplierId], references: [id])
  lotNumber              String?
  receivedDate           DateTime?
  responsibleWarehouseId String?
  responsibleWarehouse   Warehouse?       @relation("ResponsibleWarehouse", fields: [responsibleWarehouseId], references: [id])
  responsibleUserId      String?
  responsibleUser        User?            @relation("ResponsibleUser", fields: [responsibleUserId], references: [id])
  resolution             DefectResolution @default(pending)
  qcNotes                String?
  evaluatedById          String
  evaluatedBy            User             @relation("EvaluatedBy", fields: [evaluatedById], references: [id])
  evaluatedAt            DateTime         @default(now())
}

model InventoryCheckSession {
  id           String     @id @default(uuid())
  warehouseId  String
  warehouse    Warehouse  @relation(fields: [warehouseId], references: [id])
  checkType    CheckType
  shift        ShiftName?
  shiftDate    DateTime
  status       String     @default("in_progress")
  startedAt    DateTime?
  completedAt  DateTime?
  startedById  String
  startedBy    User       @relation("SessionStartedBy", fields: [startedById], references: [id])
  approvedById String?
  approvedBy   User?      @relation("SessionApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  notes        String?

  items  InventoryCheckItem[]
  photos InventoryCheckPhoto[]
}

model InventoryCheckItem {
  id                String                @id @default(uuid())
  sessionId         String
  session           InventoryCheckSession @relation(fields: [sessionId], references: [id])
  productId         String
  product           Product               @relation(fields: [productId], references: [id])
  locationId        String?
  location          WarehouseLocation?    @relation(fields: [locationId], references: [id])
  unitId            String
  unit              Unit                  @relation(fields: [unitId], references: [id])
  systemQty         Float
  actualQty         Float?
  discrepancyReason String?
  checkedAt         DateTime?
}

model InventoryCheckPhoto {
  id        String                @id @default(uuid())
  sessionId String
  session   InventoryCheckSession @relation(fields: [sessionId], references: [id])
  imageUrl  String
  takenAt   DateTime
  takenById String
  takenBy   User                  @relation(fields: [takenById], references: [id])
}

model ProductionOutput {
  id           String        @id @default(uuid())
  productId    String
  product      Product       @relation(fields: [productId], references: [id])
  quantity     Float
  unitId       String
  unit         Unit          @relation(fields: [unitId], references: [id])
  shift        ShiftName
  outputDate   DateTime
  salesOrderId String?
  salesOrder   SalesOrder?   @relation(fields: [salesOrderId], references: [id])
  voucherId    String?       @unique
  voucher      StockVoucher? @relation(fields: [voucherId], references: [id])
  recordedById String
  recordedBy   User          @relation(fields: [recordedById], references: [id])
  recordedAt   DateTime      @default(now())
}

model SystemNotification {
  id           String   @id @default(uuid())
  targetUserId String
  targetUser   User     @relation(fields: [targetUserId], references: [id])
  title        String
  body         String
  type         String
  refId        String?
  refType      String?
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())
}

